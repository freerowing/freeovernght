# ==============================================================================
# Overnght Live Restreamer Configuration Template
# Instructions: Copy this file to '.env' and fill in your private settings.
# Do NOT commit your actual '.env' file to version control.
# ==============================================================================

# --- Overnght Platform Authentication ---
# Your official credentials used to log into the streaming service portal.
ACCOUNT_EMAIL="your_email@example.com"
ACCOUNT_PASSWORD="your_secure_password"

# --- Target Route Navigation Endpoints ---
# The primary authentication page and the specific event room ID you wish to copy.
LOGIN_URL="https://www.overnght.com/auth/login"
EVENT_URL="https://www.overnght.com/event/37cb74b0-e6de-4a41-ae91-82731738110e"

# --- System File System & Networking Engine Layout ---
# Explicit absolute path layouts and local serving configurations.
# Update the username segments to match your target host operating system.
BASE_DIR="livestream"
URL_FILE="livestream/stream_url.txt"
OUTPUT_M3U8="livestream/local.m3u8"

# The local port your HLS web viewer index player will be served on.
PORT=8080
